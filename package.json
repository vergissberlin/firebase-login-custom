{
  "name": "firebase-login-custom",
  "version": "0.5.5",
  "description": "This package is a wrapper to firebase custom login including all dependencies with the exception of firebase itself.",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "neverBuiltDependencies": [
      "grpc"
    ]
  },
  "main": "dist/firebase-login-custom.js",
  "module": "dist/firebase-login-custom.es.js",
  "types": "dist/firebase-login-custom.d.ts",
  "exports": {
    ".": {
      "types": "./dist/firebase-login-custom.d.ts",
      "import": "./dist/firebase-login-custom.es.js",
      "require": "./dist/firebase-login-custom.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "watch": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "lint": "pnpm exec eslint src/ tests/",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "test:unit": "vitest run",
    "test:integration": "node -e \"const fs=require('fs'); if(!fs.existsSync('dist/firebase-login-custom.js')){ const {execSync}=require('child_process'); execSync('pnpm run build',{stdio:'inherit'}); }\" && node tests/run-integration.js",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vergissberlin/firebase-login-custom.git"
  },
  "keywords": [
    "firebase",
    "security",
    "login",
    "auth",
    "custom"
  ],
  "author": {
    "name": "André Lademann",
    "email": "vergissberlin@googlemail.com"
  },
  "maintainers": [
    {
      "name": "André Lademann",
      "email": "vergissberlin@googlemail.com"
    }
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/vergissberlin/firebase-login-custom/issues"
  },
  "homepage": "https://github.com/vergissberlin/firebase-login-custom",
  "dependencies": {
    "firebase-token-generator": "^2.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "eslint": "^10.0.3",
    "firebase": "^12.10.0",
    "husky": "^9.1.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.0"
  }
}
